{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PR Review Evaluation Dataset",
  "type": "object",
  "required": ["dataset_name", "version", "samples"],
  "properties": {
    "dataset_name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "samples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sample_id", "title", "changed_files", "diff_text", "ground_truth"],
        "properties": {
          "sample_id": {
            "type": "string"
          },
          "repo_name": {
            "type": "string"
          },
          "pr_number": {
            "type": ["integer", "null"]
          },
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "changed_files": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["filename"],
              "properties": {
                "filename": {
                  "type": "string"
                },
                "status": {
                  "type": "string"
                },
                "additions": {
                  "type": "integer"
                },
                "deletions": {
                  "type": "integer"
                }
              },
              "additionalProperties": true
            }
          },
          "diff_text": {
            "type": "string"
          },
          "ground_truth": {
            "type": "object",
            "required": ["must_find_issues", "test_focuses", "unit_test_targets", "merge_recommendation"],
            "properties": {
              "must_find_issues": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["title", "severity", "reason"],
                  "properties": {
                    "title": {
                      "type": "string"
                    },
                    "severity": {
                      "type": "string",
                      "enum": ["high", "medium", "low"]
                    },
                    "file": {
                      "type": ["string", "null"]
                    },
                    "reason": {
                      "type": "string"
                    },
                    "expected_keywords": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  },
                  "additionalProperties": true
                }
              },
              "optional_issues": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "test_focuses": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "unit_test_targets": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "merge_recommendation": {
                "type": "string",
                "enum": ["approve", "approve_with_notes", "changes_requested", "uncertain"]
              }
            },
            "additionalProperties": true
          },
          "metadata": {
            "type": "object"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
